<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/forest_dark"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏕️"
        android:textSize="64sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Campsite Commander"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/leaf_green"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvTotalItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎒 Total Items Packed: 0"
        android:textSize="18sp"
        android:textColor="@color/sand_light"
        android:gravity="center"
        android:background="@color/dark_card"
        android:padding="16dp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnAddGear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="➕ Add Gear"
        android:textSize="16sp"
        android:backgroundTint="@color/leaf_green"
        android:textColor="@color/forest_dark"
        android:layout_marginBottom="16dp"
        android:padding="14dp"/>

    <Button
        android:id="@+id/btnViewList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 View Gear List"
        android:textSize="16sp"
        android:backgroundTint="@color/earth_brown"
        android:textColor="@color/sand_light"
        android:padding="14dp"/>

</LinearLayout>
